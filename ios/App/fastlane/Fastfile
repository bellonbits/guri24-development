default_platform(:ios)

platform :ios do
  lane :build do
    # Create a temporary keychain for this CI run
    keychain_name = "app-signing"
    keychain_password = SecureRandom.hex

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # Import the distribution certificate from the file decoded by the workflow
    import_certificate(
      certificate_path: "/tmp/cert.p12",
      certificate_password: ENV["DISTRIBUTION_CERT_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    # Authenticate with App Store Connect
    api_key = app_store_connect_api_key(
      key_id: "Y7479A5B46",
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: File.expand_path("~/Downloads/AuthKey_Y7479A5B46.p8"),
      duration: 1200,
      in_house: false
    )

    # Download (or create) the App Store distribution provisioning profile
    sigh(
      api_key: api_key,
      app_identifier: "com.guri24.app",
      readonly: false
    )

    # Build and archive — use SIGH_UUID set by sigh above
    gym(
      scheme: "guri24",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "Guri24.ipa",
      clean: true,
      configuration: "Release",
      codesigning_identity: "Apple Distribution",
      xcargs: "DEVELOPMENT_TEAM=2969422VU2 CODE_SIGN_STYLE=Manual \"PROVISIONING_PROFILE[com.guri24.app]=#{ENV['SIGH_UUID']}\""
    )
  end
end
